{%- comment -%}
  sections/section-how-it-works.liquid
  How It Works section — 3-step flow with numbered gradient circles
{%- endcomment -%}

{{ 'component-how-it-works.css' | asset_url | stylesheet_tag }}

<section class="section-how-it-works" data-section-id="{{ section.id }}">
  <div class="how-it-works__inner">
    {%- if section.settings.headline != blank -%}
      <h2 class="how-it-works__headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ol class="steps-list">
        {%- for block in section.blocks -%}
          <li class="step-card" {{ block.shopify_attributes }}>
            {%- if block.settings.step_number != blank -%}
              <div class="step-number" aria-hidden="true">{{ block.settings.step_number }}</div>
            {%- endif -%}
            {%- if block.settings.step_headline != blank -%}
              <h3 class="step-headline">{{ block.settings.step_headline }}</h3>
            {%- endif -%}
            {%- if block.settings.step_body != blank -%}
              <p class="step-body">{{ block.settings.step_body }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ol>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "section-how-it-works-wrapper",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Section headline",
      "default": "How It Works"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "step_headline",
          "label": "Step headline",
          "default": "Choose Your Box"
        },
        {
          "type": "textarea",
          "id": "step_body",
          "label": "Step description",
          "default": "Select the subscription plan that works for your household."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works"
    }
  ]
}
{% endschema %}
