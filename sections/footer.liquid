{%- comment -%}
  sections/footer.liquid
  Footer with brand mark, nav columns, and configurable content blocks
  Loaded via sections/footer-group.json as OS 2.0 section group
{%- endcomment -%}

{{ 'component-footer.css' | asset_url | stylesheet_tag }}

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">

    <!-- Brand column -->
    <div class="site-footer__brand-column">
      <div class="site-footer__brand">
        {%- if section.settings.brand_text != blank -%}
          {{ section.settings.brand_text }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </div>
      {%- if section.settings.tagline != blank -%}
        <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    <!-- Merchant-configurable link columns (blocks) -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'column' -%}
        <div class="site-footer__link-column" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3>{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul role="list">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  <!-- Copyright bar -->
  <div class="site-footer__bottom">
    <p>
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
      {%- if section.settings.copyright_text != blank -%}
        {{ section.settings.copyright_text }}
      {%- else -%}
        {{ 'footer.copyright' | t }}
      {%- endif -%}
    </p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand name",
      "info": "Displayed in footer brand area. Defaults to shop name if left blank."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "placeholder": "Curated provisions, delivered."
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "info": "Displayed after the year and shop name. Defaults to 'All rights reserved.' if blank."
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
