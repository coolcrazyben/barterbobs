{%- comment -%}
  sections/section-brand-story.liquid
  Brand Story section — 2-col editorial with headline, body, pull quote, 2x2 image grid
{%- endcomment -%}

{{ 'component-brand-story.css' | asset_url | stylesheet_tag }}

<section class="section-brand-story" data-section-id="{{ section.id }}">
  <div class="brand-story__inner">
    <div class="brand-story__content">
      {%- if section.settings.headline != blank -%}
        <h2 class="brand-story__headline">{{ section.settings.headline }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="brand-story__body">{{ section.settings.body }}</div>
      {%- endif -%}
      {%- if section.settings.pull_quote != blank -%}
        <blockquote class="brand-story__pull-quote">{{ section.settings.pull_quote }}</blockquote>
      {%- endif -%}
    </div>

    <div class="brand-story__images">
      {%- assign image_ids = 'image_1,image_2,image_3,image_4' | split: ',' -%}
      {%- for image_id in image_ids -%}
        {%- assign image = section.settings[image_id] -%}
        <div class="brand-story__image-cell">
          {%- if image != blank -%}
            {%- assign brand_image_alt = image.alt | escape -%}
            {{ image | image_url: width: 600 | image_tag: class: 'brand-story__image', alt: brand_image_alt, loading: 'lazy', width: 600, height: 600 }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'brand-story__image brand-story__image--placeholder' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section-brand-story-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "The Story Behind the Box"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>We believe great food tells a story. Every product in your BarterBobs box is sourced directly from independent artisans who pour their craft into every batch.</p>"
    },
    {
      "type": "text",
      "id": "pull_quote",
      "label": "Pull quote",
      "default": "Food is our love language."
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
