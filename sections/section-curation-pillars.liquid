{%- comment -%}
  sections/section-curation-pillars.liquid
  Curation Pillars section — 3 icon+headline+body repeatable blocks
{%- endcomment -%}

{{ 'component-curation-pillars.css' | asset_url | stylesheet_tag }}

<section class="section-curation-pillars" data-section-id="{{ section.id }}">
  <div class="curation-pillars__inner">
    {%- if section.settings.headline != blank -%}
      <h2 class="curation-pillars__headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="curation-pillars__grid">
        {%- for block in section.blocks -%}
          <div class="pillar-card" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="pillar-card__icon-wrapper">
                <span class="material-symbols-outlined pillar-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
              </div>
            {%- endif -%}
            {%- if block.settings.pillar_headline != blank -%}
              <h3 class="pillar-card__headline">{{ block.settings.pillar_headline }}</h3>
            {%- endif -%}
            {%- if block.settings.pillar_body != blank -%}
              <p class="pillar-card__body">{{ block.settings.pillar_body }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Curation Pillars",
  "tag": "section",
  "class": "section-curation-pillars-wrapper",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Section headline",
      "default": "Curation with Care"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Material Symbol name)",
          "default": "favorite"
        },
        {
          "type": "text",
          "id": "pillar_headline",
          "label": "Headline",
          "default": "Thoughtfully Selected"
        },
        {
          "type": "textarea",
          "id": "pillar_body",
          "label": "Body text",
          "default": "Every product is hand-picked by our team of food experts."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Curation Pillars"
    }
  ]
}
{% endschema %}
